# KnightForge Sahayak — Backend Environment Variables
# Copy this file to `.env` for local development and provide real secret values there.
# `.env` must remain Git-ignored.
# NEVER commit real API keys, OAuth credentials, JWT secrets, or other secrets.

# ============================================================
# Application
# ============================================================

APP_NAME=KnightForge Sahayak API
APP_VERSION=0.1.0

# ============================================================
# Runtime
# ============================================================

ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ============================================================
# Server
# ============================================================

HOST=0.0.0.0
PORT=8000

# ============================================================
# CORS
# Comma-separated frontend origins allowed to call the backend.
# Replace/configure through the hosting platform for production.
# ============================================================

CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================
# OpenAI — Optional
# Leave empty if OpenAI-backed functionality is not configured.
# ============================================================

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=20

# ============================================================
# Google Gemini
# Set GEMINI_API_KEY securely in your local .env or hosting
# platform environment variables. Never commit the real key.
# ============================================================

GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest

# ============================================================
# Database
# Local development default.
# Configure an appropriate persistent database/storage path
# through the hosting platform for production.
# ============================================================

DATABASE_URL=sqlite:///./app.db

# ============================================================
# Authentication / JWT
# Production MUST use a securely generated JWT secret.
#
# Generate one with:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
#
# Set the generated value in .env locally or in the hosting
# platform's secret environment variables.
# ============================================================

JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=14

# false for local HTTP development.
# Set true in production when authentication uses HTTPS.
AUTH_COOKIE_SECURE=false

# ============================================================
# Google OAuth — Optional
# Leave CLIENT_ID and CLIENT_SECRET empty if Google OAuth
# is not configured.
#
# Configure real credentials only in .env or the production
# hosting platform's environment variables.
# ============================================================

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Local development callback.
# Replace with the deployed backend callback URL in production.
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ============================================================
# Frontend
# Local development URL.
# Replace with the deployed frontend URL in production.
# ============================================================

FRONTEND_URL=http://localhost:3000