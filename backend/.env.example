# KnightForge Sahayak — Backend environment variables (Phase 1)
# Copy this file to `.env` and adjust values. `.env` is git-ignored.
# Only variables used by the current phase are listed. Later phases (OpenAI,
# OCR, PDF) will add their own keys here when implemented.

# --- App metadata ---
APP_NAME=KnightForge Sahayak API
APP_VERSION=0.1.0

# --- Runtime ---
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- CORS (comma-separated origins allowed to call this API) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- OpenAI (Phase 5 — AI Conversation Engine) ---
# Leave OPENAI_API_KEY empty to run without AI: the conversation endpoints then
# answer with deterministic fallback phrasing built from the KYC schema.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=20
