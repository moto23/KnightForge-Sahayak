# Keep applicant data, secrets and local build artifacts OUT of the image.
#
# An image layer is permanent and distributable: anything copied in here can be
# extracted by anyone who pulls it, even if a later layer deletes the file.

# --- Secrets -------------------------------------------------------------- #
.env
.env.*
!.env.example

# --- Runtime applicant data (must come from the database / object store) --- #
uploads/
generated_pdfs/
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
_restart_state.json

# --- Local Python environment (wrong platform, and huge) ------------------- #
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# --- Tests: not needed to serve traffic ----------------------------------- #
e2e_*.py

# --- Logs ----------------------------------------------------------------- #
*.log

# --- OS / IDE ------------------------------------------------------------- #
.DS_Store
.idea/
.vscode/
