    {"canonical": "gender", "labels": ["sex", "gender"], "document_wide": true},
    {"canonical": "nationality", "labels": ["nationality"], "document_wide": true},
    {"canonical": "address", "labels": ["address"]},
    {"canonical": "pincode", "labels": ["pin code", "pincode", "pin"]},
    {"extra_key": "passport_number", "extra_label": "Passport Number", "labels": ["passport no", "passport number"], "value_kind": "passport_no", "document_wide": true},
    {"extra_key": "date_of_expiry", "extra_label": "Date of Expiry", "labels": ["date of expiry", "expiry date"], "value_kind": "date"},
    {"extra_key": "date_of_issue", "extra_label": "Date of Issue", "labels": ["date of issue", "issue date"], "value_kind": "date"},
    {"extra_key": "place_of_birth", "extra_label": "Place of Birth", "labels": ["place of birth"]},
    {"extra_key": "place_of_issue", "extra_label": "Place of Issue", "labels": ["place of issue"]},
    {"extra_key": "surname", "extra_label": "Surname", "labels": ["surname"]},
    {"extra_key": "mother_name", "extra_label": "Name of Mother", "labels": ["name of mother", "mother"]},
    {"extra_key": "mrz", "extra_label": "MRZ", "labels": [], "value_kind": "mrz", "document_wide": true}
  ]
